# App
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/approvalkit

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.approvalkit.io
AUTH0_MGMT_API_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# Auth0 FGA
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=your-store-id
FGA_MODEL_ID=your-model-id

# Security
HMAC_SECRET=your-hmac-secret-key

# Sentry
SENTRY_DSN=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
