# ─── App ────────────────────────────────────────
DEBUG=false
# Set to "development" for local testing (allows X-User-Sub header auth).
# In "production" (default), Auth0 JWT token is required.
ENVIRONMENT=development

# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://approvalkit:approvalkit@postgres:5432/approvalkit

# ─── Redis ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Providers ──────────────────────────────────
# Pluggable backends for approval channel, credential store, and
# identity provider. Defaults to "auth0" (Auth0 CIBA + Token Vault).
# Set to "local" to run without an Auth0 tenant — useful for local
# development, self-hosted setups, and CI. See docs/providers.md.
APPROVAL_PROVIDER=auth0
# Optional per-component overrides (leave empty to follow APPROVAL_PROVIDER):
# APPROVAL_CHANNEL=local
# CREDENTIAL_STORE=local
# IDENTITY_PROVIDER=local
# When the local approval channel is active, auto-approve every
# request. NEVER enable this outside of CI / integration tests.
LOCAL_APPROVAL_AUTO_APPROVE=false

# ─── Auth0 (required when APPROVAL_PROVIDER=auth0) ─────
# Create two apps in Auth0 Dashboard:
# 1. M2M app (backend) — for Token Exchange + Management API
# 2. Web app (frontend) — for user login + Connected Accounts
# See SETUP.md for detailed instructions.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-m2m-client-id
AUTH0_CLIENT_SECRET=your-m2m-client-secret
AUTH0_WEB_CLIENT_ID=your-web-client-id
AUTH0_WEB_CLIENT_SECRET=your-web-client-secret
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/me/
AUTH0_MGMT_API_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# ─── Auth0 FGA (Optional) ──────────────────────
# Fine-Grained Authorization for role-based access control.
# If not configured, all authorization checks pass (allow-all).
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=
FGA_MODEL_ID=
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=

# ─── Security ──────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=generate-a-random-64-char-hex-string
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=generate-a-fernet-key

# ─── HashiCorp Vault (Optional) ────────────────
# For production-grade secret storage. Falls back to Fernet if unavailable.
# Leave empty to disable Vault integration (Fernet encryption will be used).
VAULT_URL=
VAULT_TOKEN=

# ─── Sentry (Optional) ─────────────────────────
SENTRY_DSN=

# ─── URLs ───────────────────────────────────────
# REQUIRED: Must be changed from localhost in production deployments.
# Auth0 OAuth callbacks will NOT work if these point to localhost and the
# browser is not on the same host. Use your public HTTPS URLs in prod.
# Example (production):
#   CALLBACK_BASE_URL=https://api.yourcompany.com
#   FRONTEND_URL=https://app.yourcompany.com
CALLBACK_BASE_URL=http://localhost:8000   # CHANGE IN PRODUCTION
FRONTEND_URL=http://localhost:3000        # CHANGE IN PRODUCTION

# ─── Credential encryption rotation (Optional) ─
# Set to the previous CREDENTIALS_KEY value while rotating keys so
# existing ciphertext can still be decrypted. Remove after all records
# have been re-encrypted with the new key.
CREDENTIALS_KEY_PREVIOUS=
